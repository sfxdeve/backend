                  "if (res.success && id) {",
                  "  pm.environment.set('athleteId', String(id));",
                  "  const athleteId1 = pm.environment.get('athleteId1');",
                  "  const athleteId2 = pm.environment.get('athleteId2');",
                  "  if (!athleteId1) {",
                  "    pm.environment.set('athleteId1', String(id));",
