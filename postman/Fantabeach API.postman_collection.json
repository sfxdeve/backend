          "name": "Create Pack (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let res = {};",
                  "try { res = pm.response.json(); } catch (e) {}",
                  "const id = (res.data && (res.data._id || res.data.id)) || '';",
                  "if (res.success && id) {",
                  "  pm.environment.set('packId', String(id));",
                  "  pm.environment.set('creditPackId', String(id));",
                  "}"
                ],
