              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"gender\": \"M\",\n  \"championshipId\": \"{{championshipId}}\",\n  \"entryPoints\": 0,\n  \"globalPoints\": 0,\n  \"fantacoinCost\": 0\n}"
